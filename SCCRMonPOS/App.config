<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
  </startup>

  <appSettings>
    <!-- Backend API -->
    <add key="ApiBaseUrl" value="https://sc-official-website.onrender.com" />

    <!-- Staff device (leave DeviceName blank to default to machine hostname) -->
    <add key="StaffDeviceName" value="" />

    <!-- Scanner timing -->
    <add key="ScannerMaxIntervalMs" value="5000" />
    <add key="ScannerMinLength"     value="10" />

    <!-- Points rule — must match backend (1 pt per 10 THB) -->
    <add key="BahtPerPoint" value="10" />

    <!-- Product screening safeguard for loyalty -->
    <add key="ProductEligibilityApiBaseUrl" value="" />
    <add key="ProductEligibilityApiKey" value="" />
    <add key="RequireProductScreeningForPoints" value="true" />

    <!-- Post-sale claim QR -->
    <add key="ClaimQrEnabled" value="true" />
    <add key="ClaimQrInternalToken" value="" />
    <add key="ClaimQrPayloadPrefix" value="SCM-CLAIM-v1-" />
    <add key="ClaimQrDisplaySeconds" value="45" />
    <add key="ClaimQrLookupAttempts" value="12" />
    <add key="ClaimQrLookupDelayMs" value="5000" />

    <!-- AdaPos DB watcher — direct SQL Server read from POSSRV -->
    <add key="AdaPosEnabled"     value="true" />
    <add key="AdaPosDbServer"    value="192.168.0.127,49683" />
    <add key="AdaPosDbName"      value="AdaAcc" />
    <add key="AdaPosDbUser"      value="sa" />
    <add key="AdaPosDbPassword"  value="adasoft" />
    <add key="AdaPosPollMs"      value="3000" />
  </appSettings>
</configuration>
