<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
  </startup>

  <appSettings>
    <!-- Backend API -->
    <add key="ApiBaseUrl" value="https://sc-official-website.onrender.com" />
    <!-- POS API key — must match POS_API_KEYS on the backend (used for GET/PUT /api/members/:id) -->
    <add key="PosApiKey" value="" />

    <!-- Staff device (leave DeviceName blank to default to machine hostname) -->
    <add key="StaffDeviceName" value="" />

    <!-- PIN required to edit member info from MemberClaimForm -->
    <add key="StaffEditPin" value="123123" />

    <!-- Points rule — must match backend (1 pt per 25 THB) -->
    <add key="BahtPerPoint" value="25" />

    <!-- Manual loyalty claim hotkey (Ctrl+Alt+Q). Modifiers: Ctrl=2, Alt=1, sum=3. VK: Q=0x51 -->
    <add key="ClaimQrHotKeyModifiers"  value="3" />
    <add key="ClaimQrHotKeyVirtualKey" value="0x51" />

    <!-- AdaPos DB watcher — direct SQL Server read -->
    <add key="AdaPosEnabled"     value="true" />
    <add key="AdaPosDbServer"    value=".\SQLEXPRESS" />
    <add key="AdaPosDbName"      value="AdaAcc" />
    <add key="AdaPosDbUser"      value="sa" />
    <add key="AdaPosDbPassword"  value="adasoft" />
    <add key="AdaPosPollMs"      value="3000" />
    <add key="WatcherDiagnosticsEnabled" value="true" />
  </appSettings>
</configuration>
